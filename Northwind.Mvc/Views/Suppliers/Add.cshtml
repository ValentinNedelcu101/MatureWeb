@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model SupplierViewModel
<div class="row">
    <p>Use the form below to add a new supplier.</p>
    <form method="post">
        @Html.AntiForgeryToken()
        <div><input asp-for="Supplier.CompanyName" 
                placeholder="Compant Name"/></div>
        <div><input asp-for="Supplier.Country" 
                placeholder="Country"/></div>
        <div><input asp-for="Supplier.Phone" 
              placeholder="Phone"/></div>
        <input type="submit" value="Add" class="btn btn-outline-primary"/>
        <a href="/Home/Suppliers" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}